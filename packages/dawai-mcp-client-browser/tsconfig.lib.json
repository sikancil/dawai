{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "rootDir": "./src",
    "outDir": "./dist/esm",
    "module": "NodeNext",
    "declaration": true,
    "declarationDir": "./dist/types",
    "tsBuildInfoFile": "./dist/tsconfig.esm.tsbuildinfo",
    "emitDeclarationOnly": false,
    "forceConsistentCasingInFileNames": true,
    "types": [], // Usually empty for browser-specific packages, or specific browser types
    "lib": ["ESNext", "DOM"], // Added "DOM"
    "composite": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"],
  "references": []
}
