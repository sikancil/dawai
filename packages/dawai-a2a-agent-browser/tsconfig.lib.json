{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "rootDir": "./src",
    "outDir": "./dist/esm",
    "module": "NodeNext",
    "declaration": true,
    "declarationDir": "./dist/types",
    "tsBuildInfoFile": "./dist/tsconfig.esm.tsbuildinfo",
    "emitDeclarationOnly": false,
